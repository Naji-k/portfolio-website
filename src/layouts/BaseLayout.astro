---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}
const {
  title = "Naji Kanounji — Software Engineer",
  description = "Portfolio of Naji Kanounji, a software engineer based in Amsterdam specializing in backend development, API integrations, and automation.",
} = Astro.props;

const gaId = import.meta.env.PUBLIC_GA_ID;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Karla:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400;1,500&display=swap"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Karla:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400;1,500&display=swap"
      rel="stylesheet"
    />

    <!-- Google Analytics 4 -->
    {
      gaId && (
        <>
          <script
            is:inline
            async
            src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}
          />
          <script
            is:inline
            set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${gaId}',{send_page_view:true});`}
          />
        </>
      )
    }

    <!-- Prevent flash of wrong theme -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem("theme");
        if (stored === "dark" || !stored) {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>
  </head>
  <body
    class="bg-base text-fg font-sans antialiased transition-colors duration-300"
  >
    <slot />

    <!-- Scroll reveal observer -->
    <script>
      const observer = new IntersectionObserver(
        (entries) =>
          entries.forEach((e) => {
            if (e.isIntersecting) {
              e.target.classList.add("visible");
              observer.unobserve(e.target);
            }
          }),
        { threshold: 0.1, rootMargin: "0px 0px -40px 0px" },
      );
      document
        .querySelectorAll("[data-animate], [data-animate-stagger]")
        .forEach((el) => {
          const rect = el.getBoundingClientRect();
          if (rect.top < window.innerHeight && rect.bottom > 0) {
            el.classList.add("visible");
          } else {
            observer.observe(el);
          }
        });

      // GA4 click delegation
      document.addEventListener("click", function (e) {
        const el = (e.target as Element).closest("[data-ga-event]");
        if (!el || typeof (window as any).gtag !== "function") return;
        const d = (el as HTMLElement).dataset;
        const params: Record<string, string> = {};
        if (d.gaLinkType) params.link_type = d.gaLinkType;
        if (d.gaLocation) params.location = d.gaLocation;
        if (d.gaProjectId) params.project_id = d.gaProjectId;
        if (d.gaProjectTitle) params.project_title = d.gaProjectTitle;
        (window as any).gtag("event", d.gaEvent, params);
      });
    </script>
  </body>
</html>
