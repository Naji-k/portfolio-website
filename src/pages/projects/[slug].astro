---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import projects from '../../data/projects.json';

export async function getStaticPaths() {
  const entries = await getCollection('projects');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const meta = projects.find((p) => p.id === entry.id);
---

<BaseLayout
  title={`${entry.data.title} — Marc Doe`}
  description={entry.data.description ?? meta?.description}
>
  <!-- Back navigation -->
  <div class="fixed top-0 left-0 right-0 z-50 bg-gray-50/80 dark:bg-slate-950/80 backdrop-blur-md border-b border-gray-200 dark:border-slate-800/60">
    <div class="max-w-3xl mx-auto px-6 h-16 flex items-center justify-between">
      <a
        href="/#projects"
        class="inline-flex items-center gap-2 text-sm text-gray-500 dark:text-slate-400 hover:text-accent-500 dark:hover:text-accent-300 transition-colors"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
        </svg>
        Back to Portfolio
      </a>
      <a href="/" class="text-sm font-semibold tracking-widest uppercase text-gray-900 dark:text-white">Marc Doe</a>
    </div>
  </div>

  <main class="min-h-screen pt-28 pb-24 px-6 max-w-3xl mx-auto">
    <!-- Header -->
    <div class="mb-10" data-animate>
      <div class="flex flex-wrap gap-2 mb-4">
        {meta?.tech.map((tag) => (
          <span class="text-xs px-2 py-0.5 rounded-full bg-gray-100 dark:bg-slate-800 text-gray-600 dark:text-slate-300 border border-gray-200 dark:border-slate-700">
            {tag}
          </span>
        ))}
      </div>
      <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 dark:text-white mb-3">
        {entry.data.title}
      </h1>
      {(entry.data.description ?? meta?.description) && (
        <p class="text-lg text-gray-500 dark:text-slate-400 leading-relaxed">
          {entry.data.description ?? meta?.description}
        </p>
      )}
    </div>

    <!-- Markdown content -->
    <article class="prose-content mb-12" data-animate>
      <Content />
    </article>

    <!-- Action buttons -->
    {(entry.data.demoUrl || entry.data.githubUrl) && (
      <div class="flex flex-wrap gap-3 pt-8 border-t border-gray-200 dark:border-slate-800" data-animate>
        {entry.data.demoUrl && (
          <a
            href={entry.data.demoUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-md bg-accent-500 text-white font-medium text-sm hover:bg-accent-900 transition-colors duration-200"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
            Live Demo
          </a>
        )}
        {entry.data.githubUrl && (
          <a
            href={entry.data.githubUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-5 py-2.5 rounded-md border border-gray-300 dark:border-slate-700 text-gray-700 dark:text-slate-300 font-medium text-sm hover:border-accent-500 dark:hover:border-accent-300 hover:text-accent-500 dark:hover:text-accent-300 transition-colors duration-200"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
            </svg>
            Source Code
          </a>
        )}
      </div>
    )}
  </main>
</BaseLayout>
