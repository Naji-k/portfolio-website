---
import projects from "../data/projects.json";

const personal = projects.filter((p) => p.category === "personal");
const uni = projects.filter((p) => p.category === "uni");
---

<section id="projects" class="mx-auto max-w-5xl px-6 py-24">
  <!-- Section header -->
  <div class="mb-12" data-animate>
    <!-- <p class="text-sm font-medium text-accent-500 dark:text-accent-300 mb-2 tracking-widest uppercase">Work</p> -->
    <h2 class="text-fg text-section font-bold">Projects</h2>
  </div>

  <!-- Tab buttons -->
  <div class="border-wire mb-10 flex gap-1 border-b" data-animate>
    <button
      data-proj-tab="personal"
      class="proj-tab-btn text-fg-soft hover:text-fg text-ui -mb-px border-b-2 border-transparent px-5 py-2.5 font-medium transition-colors duration-200"
    >
      Projects
    </button>
    <button
      data-proj-tab="uni"
      class="proj-tab-btn text-fg-soft hover:text-fg text-ui -mb-px border-b-2 border-transparent px-5 py-2.5 font-medium transition-colors duration-200"
    >
      University
    </button>
  </div>

  <!-- Personal tab: featured card layout -->
  <div
    id="proj-tab-personal"
    class="proj-tab-panel tab-panel"
    data-animate-stagger
  >
    <div class="flex flex-col gap-5">
      {
        personal.map((project) => (
          <a
            href={project.hasDetail ? `/projects/${project.id}` : undefined}
            class={`group bg-panel border-wire block rounded-xl border p-8 ${project.hasDetail ? "hover:border-accent-500 dark:hover:border-accent-300 dark:hover:shadow-accent-500/10 cursor-pointer hover:-translate-y-0.5 hover:shadow-xl" : "cursor-default"} transition-all duration-300`}
          >
            <div class="flex items-start gap-6">
              <div class="from-accent-500 flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-gradient-to-br to-slate-700 text-sm font-bold text-white">
                {project.logo ? (
                  <img
                    src={project.logo}
                    alt={project.title}
                    class="h-10 w-10 object-contain"
                  />
                ) : (
                  project.title.slice(0, 2).toUpperCase()
                )}
              </div>

              <div class="min-w-0 flex-1">
                <p class="text-accent-500 dark:text-accent-300 text-tag mb-1 font-medium tracking-wider uppercase">
                  Personal Project
                </p>
                <h3 class="text-fg group-hover:text-accent-500 dark:group-hover:text-accent-300 mb-3 flex items-center gap-1.5 text-xl font-semibold transition-colors">
                  {project.title}
                  {project.hasDetail && (
                    <svg
                      class="h-4 w-4 shrink-0 opacity-0 transition-opacity group-hover:opacity-100"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="2.5"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M9 5l7 7-7 7"
                      />
                    </svg>
                  )}
                </h3>
                <p
                  class="text-fg-soft text-body mb-5 max-w-[65ch] leading-relaxed dark:leading-[1.75]"
                  style="text-wrap: pretty"
                >
                  {project.description}
                </p>
                <div class="flex flex-wrap gap-1.5">
                  {project.tech.map((tag) => (
                    <span class="bg-wire text-fg-mid border-wire text-tag rounded-full border px-2 py-0.5">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </div>

  <!-- University tab: 2-col grid -->
  <div
    id="proj-tab-uni"
    class="proj-tab-panel tab-panel hidden"
    data-animate-stagger
  >
    <div class="grid gap-5 sm:grid-cols-2">
      {
        uni.map((project) => (
          <a
            href={project.hasDetail ? `/projects/${project.id}` : undefined}
            class={`group bg-panel border-wire block rounded-xl border p-6 ${project.hasDetail ? "hover:border-accent-500 dark:hover:border-accent-300 dark:hover:shadow-accent-500/10 cursor-pointer hover:-translate-y-1 hover:shadow-lg" : "cursor-default"} transition-all duration-300`}
          >
            <div class="mb-4 flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-gradient-to-br from-slate-600 to-slate-800 text-xs font-bold text-white">
              {project.logo ? (
                <img
                  src={project.logo}
                  alt={project.title}
                  class="h-6 w-6 object-contain"
                />
              ) : (
                project.title.slice(0, 2).toUpperCase()
              )}
            </div>

            <h3 class="text-fg group-hover:text-accent-500 dark:group-hover:text-accent-300 text-card mb-2 flex items-center gap-1 font-semibold transition-colors">
              {project.title}
              {project.hasDetail && (
                <svg
                  class="h-3 w-3 shrink-0 opacity-0 transition-opacity group-hover:opacity-100"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2.5"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M9 5l7 7-7 7"
                  />
                </svg>
              )}
            </h3>

            <p
              class="text-fg-soft text-body mb-4 leading-relaxed dark:leading-[1.75]"
              style="text-wrap: pretty"
            >
              {project.description}
            </p>

            <div class="flex flex-wrap gap-1.5">
              {project.tech.map((tag) => (
                <span class="bg-wire text-fg-mid border-wire text-tag rounded-full border px-2 py-0.5">
                  {tag}
                </span>
              ))}
            </div>
          </a>
        ))
      }
    </div>
  </div>
</section>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>(".proj-tab-btn");
  const panels = document.querySelectorAll<HTMLElement>(".proj-tab-panel");
  const ACTIVE_CLS = [
    "!text-fg",
    "!border-accent-500",
    "dark:!border-accent-300",
  ];

  function activateTab(target: string) {
    tabs.forEach((btn) => {
      const isActive = btn.dataset.projTab === target;
      ACTIVE_CLS.forEach((c) => btn.classList.toggle(c, isActive));
    });
    panels.forEach((panel) => {
      panel.classList.toggle("hidden", panel.id !== `proj-tab-${target}`);
    });
  }

  tabs.forEach((btn) =>
    btn.addEventListener("click", () => activateTab(btn.dataset.projTab!)),
  );
  activateTab("personal");
</script>
