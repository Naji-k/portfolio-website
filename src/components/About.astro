---
import profile from '../data/profile.json';

const initials = profile.name
  .split(' ')
  .map((n: string) => n[0])
  .join('')
  .toUpperCase()
  .slice(0, 2);
---

<section
  id="about"
  class="py-24 px-6 max-w-5xl mx-auto"
>
  <div class="grid md:grid-cols-[1fr_auto] gap-12 items-start">
    <!-- Text content -->
    <div>
      <div class="mb-10" data-animate>
        
        <p class="text-sm font-medium text-accent-500 dark:text-accent-300 mb-2 tracking-widest uppercase">About</p>
        <h2 class="text-3xl font-bold text-gray-900 dark:text-white">Who I am</h2>
      </div>

      <p
        class="text-base text-gray-600 dark:text-slate-400 leading-relaxed dark:leading-[1.75] max-w-[65ch] mb-8"
        data-animate
        style="text-wrap: pretty"
      >
        {profile.summary}
      </p>

      <!-- Location -->
      <p class="flex items-center gap-2 text-sm text-gray-400 dark:text-slate-500 mb-8" data-animate>
        <svg class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
        </svg>
        {profile.location}
      </p>

      <!-- Skills: row layout -->
      <div class="space-y-2.5 border-t border-gray-200 dark:border-slate-800 pt-6" data-animate>
        {Object.entries(profile.skills).map(([category, items]) => (
          <div class="flex gap-5 items-start">
            <span class="text-xs font-semibold uppercase tracking-wider text-gray-400 dark:text-slate-500 w-24 pt-0.5 shrink-0">
              {category}
            </span>
            <div class="flex flex-wrap gap-1.5">
              {(items as string[]).map((skill) => (
                <span class="text-xs px-2 py-0.5 rounded bg-gray-200 dark:bg-slate-800 text-gray-700 dark:text-slate-300">
                  {skill}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
  </div>
</section>
