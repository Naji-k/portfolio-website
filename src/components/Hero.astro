---
import profile from "../data/profile.json";

const initials = profile.name
  .split(" ")
  .map((n: string) => n[0])
  .join("")
  .toUpperCase()
  .slice(0, 2);

const iconPaths: Record<string, string> = {
  terminal:
    '<path stroke-linecap="round" stroke-linejoin="round" d="M8 9l3 3-3 3m5 0h3M5 20h14a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2z" />',
  sparkles:
    '<path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456z" />',
  lightbulb:
    '<path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 0 0 1.5-.189m-1.5.189a6.01 6.01 0 0 1-1.5-.189m3.75 7.478a12.06 12.06 0 0 1-4.5 0m3.75 2.355a3.375 3.375 0 0 1-3 0M12 3c-4.418 0-8 3.582-8 8 0 2.664 1.302 5.02 3.312 6.488.358.255.688.56.688.888V18a.75.75 0 0 0 .75.75h6A.75.75 0 0 0 15 18v-.624c0-.328.33-.633.688-.888C17.698 15.02 19 12.664 19 10c0-4.418-3.582-8-7-8z" />',
};
---

<section
  class="mx-auto flex min-h-screen max-w-5xl flex-col justify-center px-6 pt-24 pb-16"
>
  <!-- Zone 1: Identity -->
  <div class="grid items-center gap-12 md:grid-cols-[1fr_auto]">
    <div>
      <p
        class="text-accent-500 dark:text-accent-300 text-tag mb-4 font-medium tracking-widest uppercase"
        data-animate
      >
        👋 Hello, I'm
      </p>

      <h1
        class="text-display text-fg mb-4 leading-[1.05] font-black tracking-tighter"
        data-animate
      >
        {profile.name}
      </h1>

      <p
        class="text-fg-soft mb-6 flex items-center gap-1 text-lg font-medium sm:text-xl"
        data-animate
      >
        {profile.title}
        <span class="cursor-blink" aria-hidden="true"></span>
      </p>

      <p
        class="text-fg-soft text-body mb-8 max-w-xl leading-relaxed"
        data-animate
      >
        {profile.tagline}
      </p>

      <!-- Social links -->
      <div class="flex flex-wrap gap-3" data-animate>
        <a
          href={profile.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="bg-accent-500 hover:bg-accent-900 dark:hover:bg-accent-300 inline-flex items-center gap-2 rounded-md px-4 py-2 text-sm font-medium text-white transition-colors duration-200 dark:hover:text-slate-900"
        >
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
            <path
              d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
            ></path>
          </svg>
          LinkedIn
        </a>
        <a
          href={profile.github}
          target="_blank"
          rel="noopener noreferrer"
          class="border-wire-soft text-fg-mid hover:border-accent-500 dark:hover:border-accent-300 hover:text-accent-500 dark:hover:text-accent-300 inline-flex items-center gap-2 rounded-md border px-4 py-2 text-sm font-medium transition-colors duration-200"
        >
          <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
            <path
              d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
            ></path>
          </svg>
          GitHub
        </a>
        <a
          href={`mailto:${profile.email}`}
          class="border-wire-soft text-fg-mid hover:border-accent-500 dark:hover:border-accent-300 hover:text-accent-500 dark:hover:text-accent-300 inline-flex items-center gap-2 rounded-md border px-4 py-2 text-sm font-medium transition-colors duration-200"
        >
          <svg
            class="h-4 w-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
            ></path>
            <polyline points="22,6 12,12 2,6"></polyline>
          </svg>
          Email
        </a>
      </div>
    </div>

    <!-- Profile photo -->
    <div class="hidden flex-col items-center md:flex" data-animate>
      <div
        class="border-wire dark:border-wire-soft from-accent-900 flex h-55 w-55 items-center justify-center overflow-hidden rounded-2xl border-2 bg-gradient-to-br to-slate-800 shadow-xl"
      >
        <img
          src={profile.photo}
          alt={`${profile.name} profile photo`}
          class="h-full w-full object-scale-down transition-transform duration-300 hover:scale-105"
          onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'"
        />
        <span
          class="hidden h-full w-full items-center justify-center text-4xl font-black tracking-tight text-white"
        >
          {initials}
        </span>
      </div>
    </div>
  </div>

  <!-- Zone 2: Specialty cards -->
  <div class="border-wire mt-10 border-t pt-10" data-animate-stagger>
    <ul class="grid grid-cols-1 gap-4 sm:grid-cols-3">
      {
        profile.specialties.map((s) => (
          <li class="bg-panel border-wire hover:border-accent-500 dark:hover:border-accent-300 rounded-xl border p-5 transition-colors duration-300">
            <span class="bg-accent-500/10 dark:bg-accent-300/10 mb-3 flex h-8 w-8 items-center justify-center rounded-lg">
              <svg
                class="text-accent-500 dark:text-accent-300 h-4 w-4"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="1.75"
                set:html={iconPaths[s.icon]}
              />
            </span>
            <p class="text-fg text-body mb-1 font-semibold">{s.title}</p>
            <p class="text-fg-soft text-body leading-relaxed">
              {s.description}
            </p>
          </li>
        ))
      }
    </ul>
  </div>

  <!-- Zone 4: Scroll hint -->
  <div class="mt-10 flex justify-center" data-animate>
    <a
      href="#about"
      class="text-fg-muted hover:text-accent-500 dark:hover:text-accent-300 text-tag flex flex-col items-center gap-2 transition-colors"
    >
      <span>Scroll</span>
      <svg
        class="h-4 w-4 animate-bounce"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"
        ></path>
      </svg>
    </a>
  </div>
</section>
