---
import ThemeToggle from "./ThemeToggle.astro";

const navLinks = [
  { label: "About", href: "#about" },
  { label: "Experience", href: "#experience" },
  { label: "Projects", href: "#projects" },
  { label: "Contact", href: "#contact" },
];
---

<header
  id="site-nav"
  class="bg-base/80 fixed top-0 right-0 left-0 z-50 border-b border-transparent backdrop-blur-md transition-all duration-300"
>
  <nav class="mx-auto flex h-16 max-w-5xl items-center justify-between px-6">
    <!-- Logo / Name -->
    <a
      href="/"
      class="text-fg hover:text-accent-500 dark:hover:text-accent-300 text-sm font-semibold tracking-widest uppercase transition-colors"
    >
      Naji Kanounji
    </a>

    <!-- Desktop links -->
    <ul class="hidden items-center gap-8 md:flex">
      {
        navLinks.map(({ label, href }) => (
          <li>
            <a
              href={href}
              data-nav-link={href}
              class="nav-link text-fg-soft hover:text-fg relative py-1 text-sm font-medium transition-colors duration-200"
            >
              {label}
              <span class="nav-indicator bg-accent-500 dark:bg-accent-300 absolute bottom-0 left-0 h-px w-0 transition-all duration-300" />
            </a>
          </li>
        ))
      }
    </ul>

    <div class="flex items-center gap-3">
      <ThemeToggle />
      <!-- Mobile hamburger -->
      <button
        id="mobile-menu-btn"
        aria-label="Open navigation menu"
        class="text-fg-soft hover:text-fg rounded-md p-2 transition-colors md:hidden"
      >
        <svg
          class="h-5 w-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="border-wire bg-base hidden border-t px-6 py-4 md:hidden"
  >
    <ul class="flex flex-col gap-4">
      {
        navLinks.map(({ label, href }) => (
          <li>
            <a
              href={href}
              class="mobile-nav-link text-fg-mid hover:text-accent-500 dark:hover:text-accent-300 block text-sm font-medium transition-colors"
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</header>

<script>
  // Mobile menu toggle
  const menuBtn = document.getElementById("mobile-menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  menuBtn?.addEventListener("click", () =>
    mobileMenu?.classList.toggle("hidden"),
  );
  document
    .querySelectorAll(".mobile-nav-link")
    .forEach((link) =>
      link.addEventListener("click", () => mobileMenu?.classList.add("hidden")),
    );

  // Nav scroll shadow
  const nav = document.getElementById("site-nav");
  window.addEventListener(
    "scroll",
    () => {
      if (window.scrollY > 10) {
        nav?.classList.add("border-wire", "shadow-sm");
      } else {
        nav?.classList.remove("border-wire", "shadow-sm");
      }
    },
    { passive: true },
  );

  // Active section highlight
  const sections = document.querySelectorAll("section[id]");
  const navLinks = document.querySelectorAll("[data-nav-link]");

  const sectionObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          navLinks.forEach((link) => {
            const isActive =
              (link as HTMLAnchorElement).getAttribute("href") ===
              `#${entry.target.id}`;
            link.classList.toggle("!text-fg", isActive);
            const indicator = link.querySelector(
              ".nav-indicator",
            ) as HTMLElement | null;
            if (indicator) indicator.style.width = isActive ? "100%" : "0";
          });
        }
      });
    },
    { threshold: 0.4, rootMargin: "-80px 0px -40% 0px" },
  );
  sections.forEach((s) => sectionObserver.observe(s));
</script>
