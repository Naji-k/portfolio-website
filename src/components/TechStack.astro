---
import profile from "../data/profile.json";

const entries = Object.entries(profile.skills);
---

<section id="stack" class="mx-auto max-w-5xl px-6 py-24">
  <div class="mb-10" data-animate>
    <p
      class="text-accent-500 dark:text-accent-300 mb-2 text-sm font-medium tracking-widest uppercase"
    >
      Skills
    </p>
    <h2 class="text-fg text-3xl font-bold">Tech Stack</h2>
  </div>

  <div
    class="bg-panel border-wire overflow-hidden rounded-xl border"
    data-animate-stagger
  >
    {
      entries.map(([category, items], i) => (
        <div
          class={`flex flex-wrap items-baseline gap-x-8 gap-y-1.5 px-6 py-5 ${i < entries.length - 1 ? "border-wire border-b" : ""}`}
        >
          <span class="text-fg-muted w-28 shrink-0 text-[10px] font-semibold tracking-[0.14em] uppercase">
            {category}
          </span>
          <p class="text-fg-soft min-w-[200px] flex-1 text-sm leading-relaxed">
            {(items as string[]).join(" · ")}
          </p>
        </div>
      ))
    }
  </div>
</section>
