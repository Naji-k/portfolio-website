---
import experience from "../data/experience.json";
import education from "../data/education.json";
---

<section id="experience" class="mx-auto max-w-5xl px-6 py-24">
  <!-- Section header -->
  <div class="mb-12" data-animate>
    <!-- <p class="text-ui font-medium text-accent-500 dark:text-accent-300 mb-2 tracking-widest uppercase">Background</p> -->
    <h2 class="text-fg text-section font-bold">Experience & Education</h2>
  </div>

  <!-- Tab buttons -->
  <div class="border-wire mb-10 flex gap-1 border-b" data-animate>
    <button
      data-exp-tab="work"
      class="exp-tab-btn text-fg-soft hover:text-fg text-ui -mb-px border-b-2 border-transparent px-5 py-2.5 font-medium transition-colors duration-200"
    >
      Work Experience
    </button>
    <button
      data-exp-tab="education"
      class="exp-tab-btn text-fg-soft hover:text-fg text-ui -mb-px border-b-2 border-transparent px-5 py-2.5 font-medium transition-colors duration-200"
    >
      Education
    </button>
  </div>

  <!-- Work Experience tab -->
  <div id="exp-tab-work" class="exp-tab-panel tab-panel" data-animate-stagger>
    {
      experience.map((job, i) => (
        <div class="relative pb-12 pl-8 last:pb-0">
          {i < experience.length - 1 && (
            <div class="bg-wire absolute top-6 bottom-0 left-[11px] w-px" />
          )}
          <div class="bg-accent-500 border-base absolute top-1.5 left-0 h-[22px] w-[22px] rounded-full border-[3px] shadow" />

          <div class="bg-panel border-wire hover:border-accent-500 dark:hover:border-accent-300 rounded-xl border p-6 transition-colors duration-300">
            <div class="mb-3 flex flex-wrap items-start justify-between gap-2">
              <div>
                <h3 class="text-fg text-card font-semibold">{job.title}</h3>
                <p class="text-accent-500 dark:text-accent-300 text-ui font-medium">
                  {job.company} · {job.location}
                </p>
              </div>
              <span class="text-fg-muted text-tag font-mono whitespace-nowrap">
                {job.startDate} — {job.endDate}
              </span>
            </div>
            <ul class="space-y-5">
              {job.highlights.map((h) => (
                <li class="text-fg-soft text-body flex gap-2 leading-relaxed dark:leading-[1]">
                  <span class="bg-accent-500 dark:bg-accent-300 mt-1.5 h-1 w-1 shrink-0 rounded-full" />
                  <span set:html={h} />
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))
    }
  </div>

  <!-- Education tab -->
  <div
    id="exp-tab-education"
    class="exp-tab-panel tab-panel hidden"
    data-animate-stagger
  >
    <!-- Degrees -->
    <div class="mb-10">
      <h3
        class="text-fg-muted text-tag mb-6 font-semibold tracking-wider uppercase"
      >
        Degrees
      </h3>
      <div class="space-y-4">
        {
          education.degrees.map((deg) => (
            <div class="bg-panel border-wire hover:border-accent-500 dark:hover:border-accent-300 rounded-xl border p-6 transition-colors duration-300">
              <div class="mb-2 flex flex-wrap items-start justify-between gap-2">
                <div>
                  <h4 class="text-fg text-card font-semibold">{deg.degree}</h4>
                  <p class="text-accent-500 dark:text-accent-300 text-ui font-medium">
                    {deg.institution} · {deg.location}
                  </p>
                </div>
                <span class="text-fg-muted text-tag font-mono whitespace-nowrap">
                  {deg.startDate} — {deg.endDate}
                </span>
              </div>
              {deg.description && (
                <p
                  class="text-fg-soft text-body leading-relaxed dark:leading-[1.75]"
                  style="text-wrap: pretty"
                >
                  {deg.description}
                </p>
              )}
            </div>
          ))
        }
      </div>
    </div>

    <!-- Courses -->
    <div>
      <h3
        class="text-fg-muted text-tag mb-4 font-semibold tracking-wider uppercase"
      >
        Courses & Certificates
      </h3>
      <div class="space-y-2">
        {
          education.courses.map((course) => (
            <div class="bg-panel border-wire flex flex-wrap items-center justify-between gap-2 rounded-lg border px-4 py-3">
              <div>
                <span class="text-fg text-ui font-medium">{course.title}</span>
                <span class="text-fg-soft text-caption ml-2">
                  {course.provider}
                </span>
              </div>
              <span class="text-fg-muted text-tag font-mono">
                {course.startDate === course.endDate
                  ? course.startDate
                  : `${course.startDate} — ${course.endDate}`}
              </span>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>(".exp-tab-btn");
  const panels = document.querySelectorAll<HTMLElement>(".exp-tab-panel");

  const ACTIVE_CLS = [
    "!text-fg",
    "!border-accent-500",
    "dark:!border-accent-300",
  ];

  function activateTab(target: string) {
    tabs.forEach((btn) => {
      const isActive = btn.dataset.expTab === target;
      ACTIVE_CLS.forEach((c) => btn.classList.toggle(c, isActive));
    });
    panels.forEach((panel) => {
      const isActive = panel.id === `exp-tab-${target}`;
      panel.classList.toggle("hidden", !isActive);
    });
  }

  tabs.forEach((btn) =>
    btn.addEventListener("click", () => activateTab(btn.dataset.expTab!)),
  );

  // Activate first tab by default
  activateTab("work");
</script>
