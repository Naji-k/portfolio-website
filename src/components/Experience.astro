---
import experience from '../data/experience.json';
import education from '../data/education.json';
---

<section
  id="experience"
  class="py-24 px-6 max-w-5xl mx-auto"
>
  <!-- Section header -->
  <div class="mb-12" data-animate>
    <!-- <p class="text-sm font-medium text-accent-500 dark:text-accent-300 mb-2 tracking-widest uppercase">Background</p> -->
    <h2 class="text-3xl font-bold text-fg">Experience & Education</h2>
  </div>

  <!-- Tab buttons -->
  <div class="flex gap-1 mb-10 border-b border-wire" data-animate>
    <button
      data-exp-tab="work"
      class="exp-tab-btn px-5 py-2.5 text-sm font-medium text-fg-soft border-b-2 border-transparent -mb-px transition-colors duration-200 hover:text-fg"
    >
      Work Experience
    </button>
    <button
      data-exp-tab="education"
      class="exp-tab-btn px-5 py-2.5 text-sm font-medium text-fg-soft border-b-2 border-transparent -mb-px transition-colors duration-200 hover:text-fg"
    >
      Education
    </button>
  </div>

  <!-- Work Experience tab -->
  <div id="exp-tab-work" class="exp-tab-panel tab-panel" data-animate-stagger>
    {experience.map((job, i) => (
      <div class="relative pl-8 pb-12 last:pb-0">
        {i < experience.length - 1 && (
          <div class="absolute left-[11px] top-6 bottom-0 w-px bg-wire"></div>
        )}
        <div class="absolute left-0 top-1.5 w-[22px] h-[22px] rounded-full bg-accent-500 border-[3px] border-base shadow"></div>

        <div class="bg-panel border border-wire rounded-xl p-6 hover:border-accent-500 dark:hover:border-accent-300 transition-colors duration-300">
          <div class="flex flex-wrap items-start justify-between gap-2 mb-3">
            <div>
              <h3 class="text-base font-semibold text-fg">{job.title}</h3>
              <p class="text-sm text-accent-500 dark:text-accent-300 font-medium">{job.company} · {job.location}</p>
            </div>
            <span class="text-xs text-fg-muted font-mono whitespace-nowrap">
              {job.startDate} — {job.endDate}
            </span>
          </div>
          <ul class="space-y-2">
            {job.highlights.map((h) => (
              <li class="flex gap-2 text-base text-fg-soft leading-relaxed dark:leading-[1.75]">
                <span class="mt-1.5 w-1 h-1 rounded-full bg-accent-500 dark:bg-accent-300 shrink-0"></span>
                <span set:html={h}></span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    ))}
  </div>

  <!-- Education tab -->
  <div id="exp-tab-education" class="exp-tab-panel tab-panel hidden" data-animate-stagger>
    <!-- Degrees -->
    <div class="mb-10">
      <h3 class="text-xs font-semibold uppercase tracking-wider text-fg-muted mb-6">Degrees</h3>
      <div class="space-y-4">
        {education.degrees.map((deg) => (
          <div class="bg-panel border border-wire rounded-xl p-6 hover:border-accent-500 dark:hover:border-accent-300 transition-colors duration-300">
            <div class="flex flex-wrap items-start justify-between gap-2 mb-2">
              <div>
                <h4 class="text-base font-semibold text-fg">{deg.degree}</h4>
                <p class="text-sm text-accent-500 dark:text-accent-300 font-medium">{deg.institution} · {deg.location}</p>
              </div>
              <span class="text-xs text-fg-muted font-mono whitespace-nowrap">
                {deg.startDate} — {deg.endDate}
              </span>
            </div>
            {deg.description && (
              <p class="text-base text-fg-soft leading-relaxed dark:leading-[1.75]" style="text-wrap: pretty">{deg.description}</p>
            )}
          </div>
        ))}
      </div>
    </div>

    <!-- Courses -->
    <div>
      <h3 class="text-xs font-semibold uppercase tracking-wider text-fg-muted mb-4">Courses & Certificates</h3>
      <div class="space-y-2">
        {education.courses.map((course) => (
          <div class="flex flex-wrap items-center justify-between gap-2 px-4 py-3 bg-panel border border-wire rounded-lg">
            <div>
              <span class="text-sm font-medium text-fg">{course.title}</span>
              <span class="ml-2 text-xs text-fg-soft">{course.provider}</span>
            </div>
            <span class="text-xs text-fg-muted font-mono">
              {course.startDate === course.endDate ? course.startDate : `${course.startDate} — ${course.endDate}`}
            </span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.exp-tab-btn');
  const panels = document.querySelectorAll<HTMLElement>('.exp-tab-panel');

  const ACTIVE_CLS = ['!text-fg', '!border-accent-500', 'dark:!border-accent-300'];

  function activateTab(target: string) {
    tabs.forEach((btn) => {
      const isActive = btn.dataset.expTab === target;
      ACTIVE_CLS.forEach((c) => btn.classList.toggle(c, isActive));
    });
    panels.forEach((panel) => {
      const isActive = panel.id === `exp-tab-${target}`;
      panel.classList.toggle('hidden', !isActive);
    });
  }

  tabs.forEach((btn) => btn.addEventListener('click', () => activateTab(btn.dataset.expTab!)));

  // Activate first tab by default
  activateTab('work');
</script>
