---
import profile from '../data/profile.json';
---

<section
  id="contact"
  class="py-24 px-6 max-w-5xl mx-auto"
>
  <div class="max-w-2xl mx-auto text-center" data-animate>
    <p class="text-sm font-mono text-accent-500 dark:text-accent-300 mb-2 tracking-widest uppercase">Get in touch</p>
    <h2 class="text-3xl font-bold text-gray-900 dark:text-white mb-4">Contact</h2>
    <p class="text-gray-600 dark:text-slate-400 leading-relaxed mb-10">
      I'm open to new opportunities, collaborations, and interesting projects.
      Whether you have a question or just want to say hi — my inbox is always open.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16">
      <a
        href={`mailto:${profile.email}`}
        class="inline-flex items-center gap-2 px-6 py-3 rounded-md bg-accent-500 dark:bg-accent-500 text-white font-medium hover:bg-accent-900 dark:hover:bg-accent-300 dark:hover:text-slate-900 transition-colors duration-200"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
          <polyline points="22,6 12,12 2,6"/>
        </svg>
        {profile.email}
      </a>

      <a
        href={profile.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-md border border-gray-300 dark:border-slate-700 text-gray-700 dark:text-slate-300 font-medium hover:border-accent-500 dark:hover:border-accent-300 hover:text-accent-500 dark:hover:text-accent-300 transition-colors duration-200"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
        </svg>
        LinkedIn
      </a>

      <a
        href={profile.github}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-6 py-3 rounded-md border border-gray-300 dark:border-slate-700 text-gray-700 dark:text-slate-300 font-medium hover:border-accent-500 dark:hover:border-accent-300 hover:text-accent-500 dark:hover:text-accent-300 transition-colors duration-200"
      >
        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
        </svg>
        GitHub
      </a>
    </div>
  </div>

  <!-- Footer -->
  <div class="border-t border-gray-200 dark:border-slate-800 pt-8 text-center text-xs text-gray-400 dark:text-slate-600">
    <p>Built with <a href="https://astro.build" target="_blank" rel="noopener" class="hover:text-accent-500 dark:hover:text-accent-300 transition-colors">Astro</a> & <a href="https://tailwindcss.com" target="_blank" rel="noopener" class="hover:text-accent-500 dark:hover:text-accent-300 transition-colors">Tailwind CSS</a></p>
  </div>
</section>
